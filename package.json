  "description": "Smart-route Mermaid code blocks: beautiful-mermaid for its 6 supported diagram types, official mermaid.js for everything else.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "mermaid",
    "beautiful-mermaid"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  }
}
